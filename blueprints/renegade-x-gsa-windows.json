{
  "_version": 3,
  "type": "custom",
  "docker": {
    "ports": {
      "game": {
        "port": "7777",
        "multiplier": "2"
      },
      "raw": {
        "port": "7778",
        "multiplier": "2"
      },
      "query": {
        "port": "27015",
        "multiplier": "1"
      },
      "rcon": {
        "port": "37015",
        "multiplier": "1"
      }
    },
    "image": {
      "name": "ghcr.io/twistedbobross/renegade-x-gsa-windows",
      "tag": "1.0.1022-ltsc2022-r1"
    },
    "envs": {
      "RENX_SERVER_NAME": "{gameserver.list_name}",
      "RENX_MAP": "{config_parameter id=\"map\"}",
      "RENX_GAME_CLASS": "{config_parameter id=\"game_class\"}",
      "RENX_MAX_PLAYERS": "{gameserver.slot_limit}",
      "RENX_GAME_PORT": "{gameserver.game_port}",
      "RENX_PEER_PORT": "{gameserver.raw_port}",
      "RENX_QUERY_PORT": "{gameserver.query_port}",
      "RENX_RCON_PORT": "{gameserver.rcon_port}",
      "RENX_WEB_PORT": "{config_parameter id=\"web_port\"}",
      "RENX_ADMIN_PASSWORD": "{config_parameter id=\"admin_password\"}",
      "RENX_SERVER_PASSWORD": "{config_parameter id=\"server_password\"}",
      "RENX_EXTRA_ARGS": "{config_parameter id=\"extra_args\"}"
    },
    "mounts": {
      "{container.home_root}/renx-data": "C:/renx-data"
    }
  },
  "dir": {
    "RenX Data": {
      "path": "\\renx-data",
      "create": true,
      "type": "normal"
    }
  },
  "game": {
    "server": {
      "wipe": [],
      "backup": {},
      "monitoring": {
        "type": "container",
        "recovery_mode": true
      }
    },
    "type": "custom",
    "config": {
      "files": {},
      "parameters": {
        "map": {
          "name": "Starting Map",
          "info": "Initial map to load. Example: CNC-Field, CNC-Walls, DEF-DarkNight, TDM-Deck.",
          "type": "text",
          "content": "CNC-Field"
        },
        "game_class": {
          "name": "Game Class",
          "info": "RenX_Game.Rx_Game for Command & Conquer maps. RenX_Coop.Rx_Game_Survival for DEF survival maps.",
          "type": "text",
          "content": "RenX_Game.Rx_Game"
        },
        "admin_password": {
          "name": "Admin Password",
          "info": "Optional admin password passed into the UDK server URL.",
          "type": "text",
          "content": ""
        },
        "server_password": {
          "name": "Server Password",
          "info": "Optional password required for players to join.",
          "type": "text",
          "content": ""
        },
        "web_port": {
          "name": "Web Port",
          "info": "Renegade X web server listen port inside the container. Default game config uses 6969.",
          "type": "text",
          "content": "6969"
        },
        "extra_args": {
          "name": "Extra Launch Args",
          "info": "Optional extra UDK command-line arguments. Leave blank for normal servers.",
          "type": "text",
          "content": ""
        }
      }
    }
  }
}
